clean-libtool:
	-rm -rf .libs _libs
	-rm -rf contrib/relic/src/.libs contrib/relic/src/_libs
	-rm -rf contrib/relic/src/arch/.libs contrib/relic/src/arch/_libs
	-rm -rf contrib/relic/src/bc/.libs contrib/relic/src/bc/_libs
	-rm -rf contrib/relic/src/bn/.libs contrib/relic/src/bn/_libs
	-rm -rf contrib/relic/src/cp/.libs contrib/relic/src/cp/_libs
	-rm -rf contrib/relic/src/dv/.libs contrib/relic/src/dv/_libs
	-rm -rf contrib/relic/src/eb/.libs contrib/relic/src/eb/_libs
	-rm -rf contrib/relic/src/ed/.libs contrib/relic/src/ed/_libs
	-rm -rf contrib/relic/src/ep/.libs contrib/relic/src/ep/_libs
	-rm -rf contrib/relic/src/epx/.libs contrib/relic/src/epx/_libs
	-rm -rf contrib/relic/src/fb/.libs contrib/relic/src/fb/_libs
	-rm -rf contrib/relic/src/fbx/.libs contrib/relic/src/fbx/_libs
	-rm -rf contrib/relic/src/fp/.libs contrib/relic/src/fp/_libs
	-rm -rf contrib/relic/src/fpx/.libs contrib/relic/src/fpx/_libs
	-rm -rf contrib/relic/src/low/easy/.libs contrib/relic/src/low/easy/_libs
	-rm -rf contrib/relic/src/low/gmp/.libs contrib/relic/src/low/gmp/_libs
	-rm -rf contrib/relic/src/md/.libs contrib/relic/src/md/_libs
	-rm -rf contrib/relic/src/mpc/.libs contrib/relic/src/mpc/_libs
	-rm -rf contrib/relic/src/pc/.libs contrib/relic/src/pc/_libs
	-rm -rf contrib/relic/src/pp/.libs contrib/relic/src/pp/_libs
	-rm -rf contrib/relic/src/rand/.libs contrib/relic/src/rand/_libs
