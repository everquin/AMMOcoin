librelic.la: $(librelic_la_OBJECTS) $(librelic_la_DEPENDENCIES) $(EXTRA_librelic_la_DEPENDENCIES) 
	$(AM_V_CCLD)$(librelic_la_LINK)  $(librelic_la_OBJECTS) $(librelic_la_LIBADD) $(LIBS)
src/runbench-test-bench.$(OBJEXT): src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)

runbench$(EXEEXT): $(runbench_OBJECTS) $(runbench_DEPENDENCIES) $(EXTRA_runbench_DEPENDENCIES) 
	@rm -f runbench$(EXEEXT)
	$(AM_V_CXXLD)$(runbench_LINK) $(runbench_OBJECTS) $(runbench_LDADD) $(LIBS)
src/runtest-test.$(OBJEXT): src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)

runtest$(EXEEXT): $(runtest_OBJECTS) $(runtest_DEPENDENCIES) $(EXTRA_runtest_DEPENDENCIES) 
	@rm -f runtest$(EXEEXT)
	$(AM_V_CXXLD)$(runtest_LINK) $(runtest_OBJECTS) $(runtest_LDADD) $(LIBS)

